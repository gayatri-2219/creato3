# Server
PORT=3001
# Use either MONGO_URI (preferred in this repo) or MONGODB_URI (Creato3 guide)
MONGO_URI=mongodb://127.0.0.1:27017/creato3
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/creato3

# Chain (match creato3-frontend .env — same appchain)
EVM_RPC=http://localhost:8545
CHAIN_ID=creato3-1

# Contract addresses (same values as VITE_*_CONTRACT in the frontend)
PROFILE_ADDRESS=0x0000000000000000000000000000000000000000
SUBSCRIPTION_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# Comma-separated creator EVM addresses for GET /api/creators (on-chain has no getAllCreators on this ABI)
CREATOR_ADDRESSES=

# CORS: comma-separated origins for production (e.g. https://your-app.vercel.app). Empty = allow all (dev).
CORS_ORIGINS=

# AI (optional — /api/ai returns mock JSON if GROQ_API_KEY is unset)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (optional alternative — not wired in routes yet; frontend may use Vercel /api/claude)
ANTHROPIC_API_KEY=

# Twitter / X cross-posting (optional — mocked if unset)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
