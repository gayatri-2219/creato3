# Local development defaults for the Creato3 appchain running on your machine.
# Optional: Creato3 API — enables Groq-powered pricing on /launch when backend has GROQ_API_KEY
VITE_BACKEND_URL=http://localhost:3001

VITE_PROFILE_CONTRACT=0xc3a2dd5085c2E74FE0A3e3Ce6e10d72581888de9
VITE_SUBSCRIPTION_CONTRACT=0xb459aF522fDae51FCf7654Adc0B00E97F74CfFdF
VITE_TREASURY_CONTRACT=0x23B115b2cc1a31E959446034890B5dA9c75A7e28
VITE_CHAIN_ID=creato3-1
VITE_EVM_RPC=http://localhost:8545
VITE_COSMOS_RPC=http://localhost:26657
VITE_REST_API=http://localhost:1317
VITE_INDEXER_URL=http://localhost:8080
VITE_TX_EXPLORER_BASE_URL=
VITE_NATIVE_DENOM=GAS
VITE_NATIVE_SYMBOL=GAS
VITE_NATIVE_NAME=GAS

VITE_ANTHROPIC_API_URL=/api/claude
VITE_AI_MODE=local
VITE_LMSTUDIO_BASE_URL=/api/lm
VITE_LMSTUDIO_MODEL=

# Optional for Vercel/serverless agent registration. Local dev can also use the backend.
# These default to VITE_EVM_RPC / VITE_PROFILE_CONTRACT / VITE_NATIVE_DENOM where possible.
# Never put real mainnet keys here.
# BOOTSTRAP_EVM_PRIVATE_KEY=0xREPLACE_WITH_FUNDED_TESTNET_SPONSOR_KEY
# BOOTSTRAP_FEE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
# AGENT_BOOTSTRAP_EVM_AMOUNT_WEI=1000000000000000
